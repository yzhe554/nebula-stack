{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "description": {
      "type": "string",
      "minLength": 1
    },
    "routes": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^\\/.*"
          },
          "method": {
            "type": "string",
            "enum": [
              "ANY",
              "GET",
              "POST",
              "PUT",
              "PATCH",
              "DELETE",
              "OPTIONS",
              "HEAD"
            ]
          },
          "target": {
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "const": "http_proxy"
                  },
                  "uri": {
                    "type": "string",
                    "format": "uri"
                  }
                },
                "required": [
                  "type",
                  "uri"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "const": "lambda"
                  },
                  "service": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "type",
                  "service"
                ],
                "additionalProperties": false
              }
            ]
          }
        },
        "required": [
          "path",
          "method",
          "target"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "routes"
  ],
  "additionalProperties": false,
  "$id": "https://example.local/packages/platform/schemas/apigateway.schema.json",
  "title": "Platform API Gateway Service",
  "description": "YAML schema for AWS API Gateway HTTP APIs deployed by the platform."
}
