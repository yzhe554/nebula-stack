{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "cidrs": {
      "type": "object",
      "properties": {
        "ipv4": {
          "type": "object",
          "properties": {
            "vpc": {
              "type": "string",
              "pattern": "^\\d{1,3}(\\.\\d{1,3}){3}\\/\\d{1,2}$"
            }
          },
          "required": [
            "vpc"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "ipv4"
      ],
      "additionalProperties": false
    },
    "zones": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string",
            "minLength": 1
          },
          "subnets": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^\\d{1,3}(\\.\\d{1,3}){3}\\/\\d{1,2}$"
            }
          }
        },
        "required": [
          "description",
          "subnets"
        ],
        "additionalProperties": false
      }
    },
    "flows": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "ports": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            }
          },
          "services": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "dynamodb",
                "kms",
                "lambda",
                "logs",
                "s3",
                "sts"
              ]
            }
          }
        },
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": false
      }
    },
    "awsEndpoints": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "gateway",
              "interface"
            ]
          },
          "serviceName": {
            "type": "string",
            "minLength": 1
          },
          "routeTableZoneNames": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "policy": {
            "type": "string",
            "const": "default"
          }
        },
        "required": [
          "type",
          "serviceName",
          "policy"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "cidrs",
    "zones",
    "flows",
    "awsEndpoints"
  ],
  "additionalProperties": false,
  "$id": "https://example.local/packages/platform/schemas/network.schema.json",
  "title": "Platform Network",
  "description": "AWS-first IPv4 network intent for one env/venture/VPC."
}
